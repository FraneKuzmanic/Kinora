# Copy these values into your shell, CI secret store, or an ignored .env file
# before running scripts/configure_supabase_auth_email.mjs --apply.

# Supabase Management API personal access token with auth config write access.
# Create one from https://supabase.com/dashboard/account/tokens.
SUPABASE_ACCESS_TOKEN=

# Optional if SUPABASE_URL is available and uses https://<project-ref>.supabase.co.
SUPABASE_PROJECT_REF=

# Existing project URL can be reused from server/.env.
SUPABASE_URL=

# Resend SMTP password. Resend uses an API key as the SMTP password.
# If RESEND_API_KEY already exists in server/.env, the script will use it.
RESEND_API_KEY=

# Sender shown on Supabase Auth emails.
SUPABASE_AUTH_SMTP_SENDER_EMAIL=noreply@kinora.live
SUPABASE_AUTH_SMTP_SENDER_NAME=Kinora

# Resend SMTP defaults.
SUPABASE_AUTH_SMTP_HOST=smtp.resend.com
SUPABASE_AUTH_SMTP_PORT=465
SUPABASE_AUTH_SMTP_USER=resend

# Site URL and redirect allowlist entries for auth links.
SUPABASE_AUTH_SITE_URL=https://kinora.live
SUPABASE_AUTH_PRODUCTION_RESET_URL=https://kinora.live/reset-password
SUPABASE_AUTH_PRODUCTION_LOGIN_URL=https://kinora.live/login
SUPABASE_AUTH_PRODUCTION_REGISTER_URL=https://kinora.live/register
SUPABASE_AUTH_EXTRA_REDIRECT_URLS=

# Only set this for a local/dev Supabase project when you intentionally want
# the Site URL to remain localhost during --apply.
SUPABASE_AUTH_ALLOW_LOCAL_SITE_URL=false
